#!/bin/bash
# kubo clipboard bridge
# Bridges katulong's image uploads into the container as a clipboard.
#
# Checks two locations:
#   1. ~/.katulong/uploads/ — host-mounted uploads (when katulong runs on host)
#   2. $KATULONG_DATA_DIR/uploads/ — local uploads (when katulong runs in-container)
#
# Usage:
#   pbpaste              — output latest clipboard text (or image path)
#   pbpaste --image      — output the path to the latest uploaded image
#   pbpaste --image-raw  — output the raw image bytes

UPLOADS_DIR="$HOME/.katulong/uploads"
LOCAL_UPLOADS="${KATULONG_DATA_DIR:-}/uploads"
CLIPBOARD_DIR="$HOME/.katulong/clipboard"
CLIPBOARD_FILE="$CLIPBOARD_DIR/.clipboard-text"

latest_image() {
    local -a dirs=()
    [ -d "$UPLOADS_DIR" ] && dirs+=("$UPLOADS_DIR")
    [ -n "$LOCAL_UPLOADS" ] && [ -d "$LOCAL_UPLOADS" ] && [ "$LOCAL_UPLOADS" != "$UPLOADS_DIR" ] && dirs+=("$LOCAL_UPLOADS")
    [ ${#dirs[@]} -eq 0 ] && return

    find "${dirs[@]}" -maxdepth 1 -type f \( -name '*.png' -o -name '*.jpg' -o -name '*.jpeg' -o -name '*.gif' -o -name '*.webp' \) -printf '%T@ %p\n' 2>/dev/null | sort -rn | head -1 | cut -d' ' -f2-
}

case "${1:-}" in
    --image)
        img=$(latest_image)
        if [ -n "$img" ]; then
            echo "$img"
        fi
        ;;
    --image-raw)
        img=$(latest_image)
        if [ -n "$img" ]; then
            cat "$img"
        fi
        ;;
    *)
        # Default: return text clipboard, or if empty, the latest image path
        if [ -f "$CLIPBOARD_FILE" ]; then
            cat "$CLIPBOARD_FILE"
        else
            img=$(latest_image)
            if [ -n "$img" ]; then
                echo "$img"
            fi
        fi
        ;;
esac
