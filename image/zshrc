# ── kubo shell ──────────────────────────────────────────────────────

export ZSH="$HOME/.oh-my-zsh"

ZSH_THEME="agnoster"

plugins=(
    git
    docker
    rust
    node
    golang
    zsh-autosuggestions
    zsh-syntax-highlighting
)

source $ZSH/oh-my-zsh.sh

# ── history ─────────────────────────────────────────────────────────
HISTSIZE=50000
SAVEHIST=50000

# ── aliases ─────────────────────────────────────────────────────────
alias ls='eza --group-directories-first'
alias ll='eza -la --group-directories-first'
alias lt='eza -la --tree --level=2'
alias cat='bat --paging=never'
alias yolo='claude --dangerously-skip-permissions'
alias ..='cd ..'
alias ...='cd ../..'

# ── fzf ─────────────────────────────────────────────────────────────
export FZF_DEFAULT_COMMAND='fd --type f --hidden --follow --exclude .git'
export FZF_CTRL_T_COMMAND="$FZF_DEFAULT_COMMAND"
[ -f /usr/share/doc/fzf/examples/key-bindings.zsh ] && source /usr/share/doc/fzf/examples/key-bindings.zsh
[ -f /usr/share/zsh/vendor-completions/_fzf ] && source /usr/share/zsh/vendor-completions/_fzf

# ── paths ───────────────────────────────────────────────────────────
export PATH="/usr/local/cargo/bin:/usr/local/go/bin:/usr/local/fnm/aliases/default/bin:$HOME/.local/bin:$PATH"
